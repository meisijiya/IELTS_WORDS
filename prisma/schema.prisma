// Prisma schema — Yasi Words
//
// Phase 4 (dev):  provider = sqlite, file at prisma/dev.db
// Phase 7 (prod): provider = postgresql, DATABASE_URL → cloud PG (Neon/Supabase)
//
// Schema fields chosen for cross-provider compatibility:
//   - String for enums (sqlite has no native enum)
//   - Json for nested arrays/objects (sqlite stores as text, postgres as jsonb)
//   - DateTime / Int / Float / Boolean: both providers support
//
// This file is single source of truth. To switch to PostgreSQL:
//   1. Edit `provider = "postgresql"`
//   2. rm -rf prisma/migrations
//   3. npx prisma migrate dev --name init
//   4. npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("user") // "admin" | "user"
  createdAt    DateTime @default(now())

  settings            UserSettings?
  sessions            Session[]
  attempts            Attempt[]
  checkins            Checkin[]
  userWords           UserWord[]
  invitationsSent     Invitation[] @relation("Inviter")
  invitationsAccepted Invitation[] @relation("Invitee")
}

model Invitation {
  id        String   @id // UUID
  code      String   @unique
  inviterId Int
  inviter   User     @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId Int?
  invitee   User?    @relation("Invitee", fields: [inviteeId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([inviterId])
  @@index([code])
}

model Wordbook {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // "concise" | "full" | "cet6"
  name        String
  description String?
  createdAt   DateTime @default(now())

  words    Word[]
  sessions Session[]
}

model Word {
  id         Int      @id @default(autoincrement())
  wordbookId Int
  wordbook   Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)

  spelling  String
  pos       String?  // combined POS string e.g. "n./v." or null
  glosses   String   // JSON: [{pos: "n.", meaning: "..."}]
  flags     String?  // JSON: ["cross_line_gloss"] or null

  // Per-user memory state lives in UserWord. Word itself is shared and
  // stateless across all users.

  userWords UserWord[]
  attemptRecords Attempt[] @relation("WordAttempts")

  @@unique([wordbookId, spelling])
  @@index([wordbookId])
}

model UserWord {
  userId Int
  wordId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  word   Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  // SM-2 simplified state, per user
  level      Int       @default(0)
  easeFactor Float     @default(2.5)
  interval   Int       @default(0)
  dueAt      DateTime?
  attempts   Int       @default(0)
  correct    Int       @default(0)
  masteredAt DateTime?
  // First time the user attempted this word. Set when the UserWord row is
  // first created (i.e. the user's first ever attempt on this word). Used to
  // distinguish "new word today" from "stale word practiced today".
  firstAttemptedAt DateTime?

  @@id([userId, wordId])
  @@index([userId, dueAt])
  @@index([userId, level])
  @@index([userId, masteredAt])
  @@index([userId, firstAttemptedAt])
}

model Session {
  id           String   @id // UUID
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordbookId   Int
  wordbook     Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  wordIds      String?  // JSON array of word IDs (null = random N from wordbook)
  // "drill" — accumulates UserWord.level/correct on attempts (default);
  // "review" — only records the Attempt row; UserWord state stays unchanged.
  mode         String   @default("drill")
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  totalWords   Int      @default(0)
  correctCount Int      @default(0)

  attempts Attempt[]

  @@index([userId, wordbookId, endedAt])
}

model Attempt {
  id        Int      @id @default(autoincrement())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordId    Int
  word      Word     @relation("WordAttempts", fields: [wordId], references: [id], onDelete: Cascade)
  typed     String
  correct   Boolean
  retries   Int      @default(0)
  errorType String?  // "spelling" | "skip" | null
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([userId, wordId])
  @@index([userId, createdAt])
}

model Checkin {
  // Daily checkin snapshot — preserved across reset so users don't lose history.
  // Created lazily on first /checkin/[date] visit, or eagerly by /api/admin/reset.
  id                    Int      @id @default(autoincrement())
  userId                Int
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                  String   // "YYYY-MM-DD"
  totalAttempts         Int      @default(0)
  correctCount          Int      @default(0)
  accuracy              Float    @default(0)
  // Distinct words whose UserWord.masteredAt falls within [date 00:00, date+1 00:00).
  // Reflects actual mastery promotion/de-master events; bounded by de-master
  // semantics (a de-master on the same day clears masteredAt and may flip the
  // count back to 0 until level climbs back to the threshold).
  masteredTodayCount   Int      @default(0)
  // Distinct words attempted today that are currently in the "learning" state:
  // userWord row exists with attempts > 0 AND masteredAt IS NULL. A new word
  // that has been attempted but still has no UserWord row yet is NOT counted
  // here — it would show up on the next /checkin visit after the UserWord row
  // is upserted.
  learningCount         Int      @default(0)
  wordsAttempted        Int      @default(0)
  sessionsCount         Int      @default(0)
  cumulativeMastered    Int      @default(0)
  topMissedJson         String   @default("[]") // JSON: Mistake[]
  wordbookBreakdownJson String   @default("{}") // JSON: Record<wordbookId, WordbookStat>
  createdAt             DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model UserSettings {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashMs               Int      @default(800)
  fadeMs                Int      @default(300)
  // "both" | "flash" | "feedback" | "off" — pronounces on flash-phase and/or feedback-phase
  pronunciationMode     String   @default("both")
  // "review" (default: 复习优先) | "balanced" (14/5/1) | "new" (新词优先) — 拉取优先级
  pullPriority          String   @default("review")
  // @deprecated — superseded by pronunciationMode. Kept for back-compat reads.
  enablePronunciation   Boolean  @default(true)
  accent                String   @default("us") // "us" | "uk"
  // null = infinite (keep all Checkin snapshots). N > 0 = upper bound enforced by /api/admin/checkin/cleanup.
  // Snapshot invariant ("cross-reset preservation") still holds: /api/admin/reset snapshots today
  // before wiping attempts; retention only caps how far back snapshots may accumulate.
  checkinRetentionDays  Int?
  // Consecutive-correct count that promotes a word to "mastered". Range [2, 20].
  // Backed by UserWord.level reaching the threshold; /api/settings PUT that lowers this value
  // runs an eager promotion (UPDATE UserWord SET masteredAt = now() WHERE level >= new AND
  // masteredAt IS NULL) in the same $transaction as the settings write. The canonical
  // "is mastered" signal stays UserWord.masteredAt != null — promotion is what makes that
  // invariant hold for the new threshold.
  masteryThreshold      Int      @default(5)
  // Optional: words at or above this level skip the visual flash phase (text hidden)
  // but pronunciation still plays during the (silent) flash window. null = disabled.
  // Range [1, 100]; meaningless if >= masteryThreshold (mastered words are not
  // surfaced in practice queues). Independent of masteryThreshold (no auto-derive).
  flashSkipMinLevel     Int?
  // Master mute for chime / buzz / streak SFX. Pronunciation playback is
  // controlled separately by pronunciationMode; this only silences the
  // Web Audio synth effects.
  soundEnabled          Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}
