# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
debug_*.ts
check_*.ts

# env files
.env*
!.env.example
!.env.docker.example

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/prisma/dev.db
/prisma/dev.db-journal

# Phase 3 raw data + diffs (large intermediate files)
/raw/
/diff/
/parsed/

# Audit dir: scripts + reports are tracked, ignore generated TSV/HTML intermediates.
/audit/*.tsv
/audit/*.html

# WSL writes these Zone.Identifier files when crossing NTFS boundaries.
*:Zone.Identifier



# Planning + omo metadata (generated locally)
/.planning/
/.omo/
/.codegraph/

# Python tooling caches
__pycache__/
*.pyc
.tox/
.venv/

# PDF source (large)
/*.pdf

# Audio pronunciation files (large binaries, regenerated by tools/fetch_pronunciations.py)
/public/audio/

# Pre-baked audio release tarballs (optional build input, not source of truth)
/release/*.tar.gz
/release/*.tgz

# OS
Thumbs.db

# Local handoff / internal notes (team only, not part of upstream)
/HANDOFF.md
/HANDOFF.txt